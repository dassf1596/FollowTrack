{
  "manifest_version": 3,
  "name": "FollowTrack Helper",
  "version": "1.0",
  "description": "Automatically captures Instagram followers and following lists and imports them into FollowTrack.",
  "permissions": [
    "cookies"
  ],
  "host_permissions": [
    "https://*.instagram.com/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://*.instagram.com/*"],
      "js": ["content_main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://*.instagram.com/*"],
      "js": ["content_isolated.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ]
}
